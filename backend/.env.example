# Boola Backend Configuration

# ===========================================
# Database (PostgreSQL with pgvector)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boola

# ===========================================
# LLM Inference (vLLM)
# ===========================================
# vLLM server URL (OpenAI-compatible API)
VLLM_BASE_URL=http://localhost:8001/v1

# API key (not required for local vLLM)
VLLM_API_KEY=not-needed

# Model name (must match what vLLM is serving)
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# ===========================================
# Embedding Model
# ===========================================
# HuggingFace model for embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ===========================================
# Yale APIs (Optional)
# ===========================================
# Apply at Yale API Portal for these keys
# YALE_API_KEY=your-api-key-here

# ===========================================
# Cloud LLM Fallback (Optional)
# ===========================================
# Use these if vLLM is unavailable
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# ===========================================
# Application Settings
# ===========================================
ENVIRONMENT=development
DEBUG=true

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
